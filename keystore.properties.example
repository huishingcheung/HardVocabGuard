# 将此文件复制为 keystore.properties 并填写真实信息（不要提交 keystore.properties）
# storeFile 可填相对路径，例如：keystore/release.jks
#
# GitHub Actions 自动签名（默认）使用：
# - SIGNING_KEYSTORE_BASE64
# - SIGNING_PASSWORD（同时作为 storePassword 与 keyPassword）
# 并固定 alias 为 hardvocabguard

storeFile=keystore/release.jks
storePassword=CHANGE_ME
keyAlias=hardvocabguard
keyPassword=CHANGE_ME

